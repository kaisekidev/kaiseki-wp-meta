{
  "name": "kaiseki/wp-meta",
  "type": "library",
  "description": "Fluent, type-safe DSL for registering WordPress meta.",
  "keywords": [
    "wordpress",
    "module"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kaisekidev/kaiseki-wp-meta",
  "authors": [
    {
      "name": "Kaiseki",
      "email": "hello@kaiseki.dev",
      "homepage": "https://www.kaiseki.dev",
      "role": "Organization"
    },
    {
      "name": "David Mondok",
      "email": "david@woda.at",
      "homepage": "https://github.com/davidmondok",
      "role": "Developer"
    },
    {
      "name": "Wolfgang Schaefer",
      "email": "wolfgang@woda.at",
      "homepage": "https://github.com/wolfgangschaefer",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/kaisekidev/kaiseki-wp-meta/issues",
    "source": "https://github.com/kaisekidev/kaiseki-wp-meta"
  },
  "require": {
    "php": "^8.2",
    "kaiseki/config": "^2.0",
    "kaiseki/wp-hook": "^2.0",
    "psr/container": "^1.1 || ^2.0"
  },
  "require-dev": {
    "bnf/phpstan-psr-container": "^1.1",
    "brain/monkey": "^2.6",
    "kaiseki/php-coding-standard": "^1.0",
    "maglnet/composer-require-checker": "^4.0",
    "mockery/mockery": "^1.6",
    "php-stubs/wordpress-stubs": "^6.2",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^11.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Kaiseki\\WordPress\\Meta\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kaiseki\\Test\\WordPress\\Meta\\": "tests"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "check": [
      "@check-deps",
      "@cs-check",
      "@phpstan",
      "@phpunit"
    ],
    "check-deps": "composer-require-checker --config-file=require-checker.config.json",
    "cs-check": "php-cs-fixer fix --dry-run",
    "cs-fix": "php-cs-fixer fix --allow-risky=yes",
    "phpstan": "phpstan analyse --memory-limit 1G",
    "phpunit": "phpunit"
  }
}
